# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.

# Office 365 user credentials (no Azure AD app registration needed)
M365_USERNAME=your-email@smartsourcing.ph
M365_PASSWORD=your-password

# SharePoint target
# Full URL of the SharePoint site (not a subpage — just the site root)
# Example: https://smartsourcing.sharepoint.com/sites/Finance
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/your-site

# Server-relative folder path inside the document library
# Example: Shared Documents/Payroll Reminders
SHAREPOINT_FOLDER=Shared Documents/Payroll Reminders
